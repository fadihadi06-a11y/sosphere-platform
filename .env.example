# ═══════════════════════════════════════════════════════
# SOSphere Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Supabase (Required) ──────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google OAuth (Required) ──────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Native Capacitor build substitution (read by build script):
GOOGLE_SERVER_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Firebase Cloud Messaging (Optional — for push notifications) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ═══════════════════════════════════════════════════════
# Supabase Edge Function Secrets (set via supabase CLI)
# supabase secrets set KEY=VALUE
# ═══════════════════════════════════════════════════════

# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_API_KEY_SID=
# TWILIO_API_KEY_SECRET=
# TWILIO_TWIML_APP_SID=
# TWILIO_FROM_NUMBER=
# SOSPHERE_BASE_URL=https://sosphere-platform.vercel.app
# RESEND_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
