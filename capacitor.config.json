{
  "appId": "com.sosphere.app",
  "appName": "SOSphere",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "buildOptions": {
      "signingType": "apksigner"
    },
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 0
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "380367770593-080m690rtj5aatdhmk483bu2i24198v0.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  }
}
