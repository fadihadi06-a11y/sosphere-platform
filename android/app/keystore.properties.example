# ═══════════════════════════════════════════════════════════════════════════
# SOSphere — Android release signing keystore properties
# ─────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Run scripts/release-signing.sh (it generates the keystore + creates
#      keystore.properties interactively).
#   2. Or copy this file to `keystore.properties` and fill in the values.
#
# SECURITY:
#   • keystore.properties is gitignored — NEVER commit it.
#   • The .jks/.keystore file must also stay out of git.
#   • Losing this keystore means you can NEVER update the app on Play Store.
#     Back it up encrypted in 2-3 places (password manager, offline drive).
# ═══════════════════════════════════════════════════════════════════════════

# Path to the keystore file. Relative to android/app/ OR an absolute path.
# Recommended: keep it inside android/app/ and gitignored.
storeFile=sosphere-release.jks

# Password you set when running keytool.
# For CI, use the SOSPHERE_KEYSTORE_PASSWORD environment variable instead.
storePassword=CHANGE_ME_KEYSTORE_PASSWORD

# Key alias (default "sosphere" if you used the helper script).
keyAlias=sosphere

# Key password. Usually the same as storePassword; if you chose a different
# password for the key during keytool, put it here.
keyPassword=CHANGE_ME_KEY_PASSWORD
