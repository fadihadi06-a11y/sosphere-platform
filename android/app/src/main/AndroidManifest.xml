<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- O-C1: Android 13+ runtime permissions -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- FIX 2026-04-23: Biometric auth. USE_BIOMETRIC for API 28+,
         USE_FINGERPRINT as backward-compat for Android 6.0–8.x devices
         (includes many Huawei / MIUI handsets still in use). Without
         these, the Aparajita plugin's checkBiometry() returns
         isAvailable:false even on devices with enrolled fingerprints. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <!--
      Android 11+ package visibility. Without this <queries> block, apps targeting
      API 30+ cannot see or resolve other apps installed on the device. This is
      required for TelecomManager.getDefaultDialerPackage() to return a non-null
      value on some OEMs, and for PackageManager.queryIntentActivities(ACTION_CALL)
      to return the list of dialers we filter on.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.CALL" />
            <data android:scheme="tel" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
        <!-- Explicitly allow resolving known system dialer packages -->
        <package android:name="com.google.android.dialer" />
        <package android:name="com.android.dialer" />
        <package android:name="com.samsung.android.dialer" />
        <package android:name="com.samsung.android.contacts" />
        <package android:name="com.miui.phone" />
        <package android:name="com.huawei.contacts" />
        <package android:name="com.oppo.contacts" />
        <package android:name="com.coloros.contacts" />
        <package android:name="com.vivo.contacts" />
        <package android:name="com.oneplus.contacts" />
        <package android:name="com.asus.contacts" />
    </queries>

    <!-- O-C2: disable Auto Backup, use strict backup/extraction rules -->
    <application
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              BLOCKER #21 (2026-04-28): Deep-link intent-filters.

              Without these, links from system notifications, emails
              (Supabase auth callbacks, password reset), Stripe payment
              redirects, and shared SOS viewer URLs all open in the
              external browser instead of the app - breaking auth flow.

              Three filters:
                A) Custom scheme `sosphere://` - notification taps
                B) HTTPS App Links - sosphere-platform.vercel.app paths
                   (autoVerify=true; needs assetlinks.json on domain
                   for chooser-free behavior - tracked as BLOCKER #21b)

              CATEGORY semantics:
                - DEFAULT: required so implicit Intents are matched
                - BROWSABLE: required so links from web/mail can launch us
            -->

            <!-- A) Custom scheme - sosphere:// (no browser dialog) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="sosphere" />
            </intent-filter>

            <!-- B) HTTPS App Links - Supabase auth callbacks -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="sosphere-platform.vercel.app"
                      android:pathPrefix="/auth" />
            </intent-filter>

            <!-- B) HTTPS App Links - password reset flow -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="sosphere-platform.vercel.app"
                      android:pathPrefix="/reset-password" />
            </intent-filter>

            <!-- B) HTTPS App Links - Stripe payment returns -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="sosphere-platform.vercel.app"
                      android:pathPrefix="/payment-success" />
                <data android:scheme="https"
                      android:host="sosphere-platform.vercel.app"
                      android:pathPrefix="/payment-cancelled" />
            </intent-filter>

            <!-- B) HTTPS App Links - shared SOS viewer -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="sosphere-platform.vercel.app"
                      android:pathPrefix="/shared-sos" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
</manifest>
